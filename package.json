    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.0",
    "@supabase/supabase-js": "^2.46.0",
    "@xstate/react": "^6.1.0",
    "clsx": "^2.1.0",
    "howler": "^2.2.4",
    "next": "^16.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "three": "^0.170.0",
