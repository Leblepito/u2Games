{
  "name": "u2games",
  "version": "0.1.0",
  "private": true,
  "description": "RoosterVerse — 3D turn-based RPG browser game",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "optimize-models": "find src/assets/models -name '*.glb' ! -name '*-transformed*' -exec npx gltfjsx {} --transform --types --shadows \\;"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@react-three/fiber": "^9.0.0",
    "@react-three/drei": "^9.120.0",
    "@react-three/postprocessing": "^2.16.0",
    "three": "^0.170.0",
    "zustand": "^5.0.0",
    "xstate": "^5.18.0",
    "@xstate/react": "^4.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@supabase/supabase-js": "^2.46.0",
    "howler": "^2.2.4",
    "tunnel-rat": "^0.1.2",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.170.0",
    "@types/howler": "^2.2.11",
    "typescript": "^5.7.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "vitest": "^2.1.0",
    "@testing-library/react": "^16.0.0",
    "gltfjsx": "^6.5.0",
    "@gltf-transform/cli": "^4.0.0",
    "r3f-perf": "^7.2.0"
  }
}
