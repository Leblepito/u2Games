    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.3",
    "gltfjsx": "^6.5.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
